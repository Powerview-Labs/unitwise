# ============================================================================
# UNITWISE ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# 
# SECURITY INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Replace all placeholder values with your actual credentials
# 3. NEVER commit .env to version control
# 4. Add .env to .gitignore
# 5. Share .env securely via encrypted channels (NOT email/Slack)
# 
# SETUP STEPS:
# 1. cp .env.example .env
# 2. Edit .env with your actual values
# 3. Restart the app after changing .env values
# 
# ============================================================================

# ----------------------------------------------------------------------------
# BACKEND API CONFIGURATION
# ----------------------------------------------------------------------------

# Base URL for Cloud Functions API
# Development: Use Firebase emulator (http://localhost:5001/...)
# Production: Use deployed Firebase Functions URL (https://...)
# SECURITY: MUST use HTTPS in production
API_BASE_URL=http://localhost:5001/unitwise-83a71/us-central1

# API request timeout in milliseconds
# Prevents hanging requests and improves UX
API_TIMEOUT=30000

# ----------------------------------------------------------------------------
# FIREBASE CONFIGURATION
# ----------------------------------------------------------------------------

# Firebase Project ID
# Found in Firebase Console → Project Settings
FIREBASE_PROJECT_ID=unitwise-83a71

# Firebase API Key
# Found in Firebase Console → Project Settings → General
# SECURITY: This is a public API key (safe to expose in mobile apps)
# Firebase security is enforced via Firestore Rules and App Check
FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Firebase Auth Domain
# Usually: your-project-id.firebaseapp.com
FIREBASE_AUTH_DOMAIN=unitwise-83a71.firebaseapp.com

# Firebase Storage Bucket
# Usually: your-project-id.appspot.com
FIREBASE_STORAGE_BUCKET=unitwise-83a71.appspot.com

# Firebase Messaging Sender ID
# Found in Firebase Console → Project Settings → Cloud Messaging
FIREBASE_MESSAGING_SENDER_ID=123456789012

# Firebase App ID
# Found in Firebase Console → Project Settings → Your apps
FIREBASE_APP_ID=1:123456789012:android:abcdef1234567890

# ----------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# ----------------------------------------------------------------------------

# Application environment
# Values: development | staging | production
# SECURITY: Controls logging verbosity and error handling
APP_ENV=development

# Application name (displayed in app)
APP_NAME=UnitWise

# Application version (must match pubspec.yaml)
APP_VERSION=1.0.0

# ----------------------------------------------------------------------------
# AUTHENTICATION CONFIGURATION
# ----------------------------------------------------------------------------

# OTP code length (number of digits)
# SECURITY: Must match backend configuration
OTP_LENGTH=6

# OTP expiry time in seconds
# SECURITY: Must match backend configuration (300 = 5 minutes)
OTP_EXPIRY_SECONDS=300

# Maximum login attempts before account lockout
# SECURITY: Prevents brute force attacks
MAX_LOGIN_ATTEMPTS=5

# Session timeout in minutes
# SECURITY: Auto-logout after inactivity
# 0 = no timeout (not recommended for production)
SESSION_TIMEOUT_MINUTES=30

# Maximum OTP requests per hour (per phone number)
# SECURITY: Prevents OTP spam and abuse
MAX_OTP_REQUESTS_PER_HOUR=3

# Resend OTP cooldown in seconds
# SECURITY: Prevents rapid OTP resend requests
RESEND_OTP_COOLDOWN_SECONDS=30

# ----------------------------------------------------------------------------
# SECURITY CONFIGURATION
# ----------------------------------------------------------------------------

# Enable secure storage encryption
# SECURITY: Uses platform keystore (Android) / keychain (iOS)
# Should always be true in production
ENABLE_SECURE_STORAGE=true

# Enable certificate pinning (advanced security)
# SECURITY: Prevents man-in-the-middle attacks
# Requires SSL certificate hash configuration
ENABLE_CERTIFICATE_PINNING=false

# Enable biometric authentication (future feature)
# SECURITY: Fingerprint/Face ID for quick login
ENABLE_BIOMETRIC_AUTH=false

# Enable app attestation (Firebase App Check)
# SECURITY: Prevents unauthorized API access
# Requires Firebase App Check setup
ENABLE_APP_CHECK=false

# ----------------------------------------------------------------------------
# FEATURE FLAGS
# ----------------------------------------------------------------------------

# Enable location-based DisCo detection
# Requires geolocator permission
ENABLE_LOCATION_FEATURES=true

# Enable email notifications
# Requires email verification
ENABLE_EMAIL_NOTIFICATIONS=true

# Enable SMS fallback for OTP
# Uses Twilio/Termii SMS if WhatsApp fails
ENABLE_SMS_FALLBACK=true

# Enable dark mode
# User preference, saved in SharedPreferences
ENABLE_DARK_MODE=true

# Enable analytics (Firebase Analytics)
# SECURITY: Tracks app usage without PII
ENABLE_ANALYTICS=false

# Enable crash reporting (Firebase Crashlytics)
# SECURITY: Helps debug production issues
ENABLE_CRASH_REPORTING=false

# ----------------------------------------------------------------------------
# LOGGING CONFIGURATION
# ----------------------------------------------------------------------------

# Log level: none | error | warning | info | debug | verbose
# SECURITY: Use 'error' or 'warning' in production to avoid logging PII
LOG_LEVEL=debug

# Enable network request logging
# SECURITY: Logs HTTP requests/responses (disable in production)
LOG_NETWORK_REQUESTS=true

# Enable Firebase Firestore debug logging
# SECURITY: Logs database queries (disable in production)
LOG_FIRESTORE_QUERIES=false

# ----------------------------------------------------------------------------
# UI CONFIGURATION
# ----------------------------------------------------------------------------

# Default theme mode: light | dark | system
DEFAULT_THEME_MODE=light

# Enable splash screen animation
ENABLE_SPLASH_ANIMATION=true

# Splash screen duration in milliseconds
SPLASH_DURATION=2000

# ----------------------------------------------------------------------------
# EXTERNAL SERVICES (Future Integration)
# ----------------------------------------------------------------------------

# Google Maps API Key (for location services)
# SECURITY: Restrict API key to your app's package name
GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Paystack Public Key (for payments - future feature)
# SECURITY: Public key is safe to expose
PAYSTACK_PUBLIC_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Flutterwave Public Key (alternative payment gateway)
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX-X

# ----------------------------------------------------------------------------
# DEVELOPMENT & TESTING
# ----------------------------------------------------------------------------

# Enable mock API responses (for testing without backend)
# SECURITY: MUST be false in production
ENABLE_MOCK_API=false

# Enable test mode (bypasses some validations)
# SECURITY: MUST be false in production
ENABLE_TEST_MODE=false

# Mock user credentials (for automated testing)
# SECURITY: NEVER use in production
TEST_PHONE_NUMBER=+2348100000000
TEST_OTP_CODE=123456

# ----------------------------------------------------------------------------
# COMPLIANCE & LEGAL
# ----------------------------------------------------------------------------

# Terms & Conditions URL
TERMS_URL=https://unitwise.app/terms

# Privacy Policy URL
PRIVACY_URL=https://unitwise.app/privacy

# Support email
SUPPORT_EMAIL=support@unitwise.app

# Support phone (WhatsApp)
SUPPORT_PHONE=+2348100000000

# ----------------------------------------------------------------------------
# IMPORTANT SECURITY REMINDERS
# ----------------------------------------------------------------------------
# 
# ✅ DO:
# - Keep .env file secure and private
# - Use strong, unique values for production
# - Rotate credentials regularly
# - Use HTTPS for all API_BASE_URL in production
# - Enable all security features in production
# - Set LOG_LEVEL to 'error' or 'warning' in production
# - Review and update environment variables before each release
# 
# ❌ DON'T:
# - Commit .env to version control (add to .gitignore)
# - Share .env via unsecured channels (email, Slack, SMS)
# - Use development credentials in production
# - Hardcode any values from .env in source code
# - Enable test/mock modes in production builds
# - Log sensitive data (tokens, passwords, OTPs)
# - Use HTTP (non-encrypted) for production API_BASE_URL
# 
# ----------------------------------------------------------------------------
